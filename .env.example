# Скопируйте в .env и заполните. НЕ коммитьте .env (там токены).
MAX2TG_TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token
MAX2TG_TELEGRAM_CHAT_ID=2097379459
# Optional: Telegram supergroup with Topics enabled. The bot must be admin
# and must have permission to manage topics.
MAX2TG_TELEGRAM_TOPICS_ENABLED=false
MAX2TG_TELEGRAM_FORUM_CHAT_ID=
MAX2TG_TELEGRAM_FALLBACK_CHAT_ID=2097379459
MAX2TG_TELEGRAM_PRELOAD_TOPICS=false
MAX2TG_TELEGRAM_SEED_LAST_MESSAGES=false
MAX2TG_TELEGRAM_PRELOAD_CHAT_COUNT=100
# Токен из web.max.ru (F12 -> Console):
#   copy(JSON.parse(localStorage.__oneme_auth).token)
MAX2TG_MAX_TOKEN=paste-your-max-session-token-here
